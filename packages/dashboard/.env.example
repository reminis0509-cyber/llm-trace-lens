VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# LINE LIFF ID — obtained from the LINE Developers console. Optional:
# when unset, LIFF SDK init is skipped and the dashboard works normally
# in a regular browser. Set for LINE in-app browser demo flows.
VITE_LINE_LIFF_ID=
# LINE 公式アカウント友だち追加 URL — 右下フローティングマスコット (FloatingMascot.tsx) の
# クリック先。Founder が LINE Manager で正式 URL を取得後に設定。
# 未設定時はプレースホルダー https://line.me/R/ti/p/@fujitrace を使用する。
VITE_LINE_OFFICIAL_URL=https://line.me/R/ti/p/@fujitrace
