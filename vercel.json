{
  "version": 2,
  "installCommand": "npm install && cd packages/landing && npm install && cd ../dashboard && npm install",
  "buildCommand": "npm run build:all",
  "outputDirectory": "build",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/v1/(.*)", "destination": "/api/index.ts" },
    { "source": "/health", "destination": "/api/index.ts" },
    { "source": "/terms", "destination": "/index.html" },
    { "source": "/privacy", "destination": "/index.html" },
    { "source": "/company", "destination": "/index.html" },
    { "source": "/sales", "destination": "/index.html" },
    { "source": "/for-engineers", "destination": "/index.html" },
    { "source": "/chatbot", "destination": "/index.html" },
    { "source": "/hp-create", "destination": "/index.html" },
    { "source": "/dashboard/(.*)", "destination": "/dashboard/index.html" },
    { "source": "/dashboard", "destination": "/dashboard/index.html" }
  ]
}
