{
  "version": 2,
  "installCommand": "npm install && npm install --prefix packages/landing && npm install --prefix packages/dashboard",
  "buildCommand": "npm run build:all",
  "outputDirectory": "build",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/stream/office-task", "destination": "/api/stream/office-task.ts" },
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/v1/(.*)", "destination": "/api/index.ts" },
    { "source": "/health", "destination": "/api/index.ts" },
    { "source": "/webhook/(.*)", "destination": "/api/index.ts" },
    { "source": "/terms", "destination": "/index.html" },
    { "source": "/privacy", "destination": "/index.html" },
    { "source": "/company", "destination": "/index.html" },
    { "source": "/sales", "destination": "/index.html" },
    { "source": "/for-engineers", "destination": "/index.html" },
    { "source": "/tools", "destination": "/index.html" },
    { "source": "/tools/(.*)", "destination": "/index.html" },
    { "source": "/tutorial", "destination": "/index.html" },
    { "source": "/tutorial/(.*)", "destination": "/index.html" },
    { "source": "/blog", "destination": "/index.html" },
    { "source": "/blog/(.*)", "destination": "/index.html" },
    { "source": "/liff/tutorial", "destination": "/index.html" },
    { "source": "/liff/quest", "destination": "/dashboard/index.html" },
    { "source": "/dashboard/(.*)", "destination": "/dashboard/index.html" },
    { "source": "/dashboard", "destination": "/dashboard/index.html" }
  ]
}
